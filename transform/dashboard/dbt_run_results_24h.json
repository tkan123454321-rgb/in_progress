                    "format": 0,
                    "rawSQL": "SELECT\n    status,\n    count(*) as test_count,\n    -- LOGIC: Nếu status là fail thì mới gom tên và nối chuỗi, còn lại để trống\n    CASE \n        WHEN status = 'fail' THEN array_join(array_agg(name), ', ') \n        ELSE '' \n    END as fail_details\nFROM lakehouse.elementary.dbt_run_results \nWHERE\n    resource_type = 'test' \n    AND created_at > now() - interval '24' hour\nGROUP BY status\n",
